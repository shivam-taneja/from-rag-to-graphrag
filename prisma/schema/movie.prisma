model Movie {
  id       String   @id @default(cuid())
  title    String
  director String
  genre    String
  year     Int
  plot     String   @db.Text
  actors   String[]

  chunks MovieChunk[]
}

model MovieChunk {
  id        String                       @id @default(cuid())
  movieId   String
  movie     Movie                        @relation(fields: [movieId], references: [id], onDelete: Cascade)
  content   String                       @db.Text
  embedding Unsupported("vector(1536)")?
}
